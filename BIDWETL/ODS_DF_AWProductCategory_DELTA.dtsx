      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SELECT COUNT(1) As CNT FROM&quot; + @[User::DELTA_TABLE_FULL_NAME]  + &quot; WHERE Action = 'UPDATE' AND [LOAD_ID] = &quot; + ( (DT_WSTR, 8) @[User::LOAD_ID])"
