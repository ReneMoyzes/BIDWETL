    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{2CFBD8CA-25A4-40A0-AAF1-779D4D1E47B4}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE  @ActionLoadID int=?;&#xA;&#xA;MERGE &quot; + @[User::ODS_TABLE_FULL_NAME] + &quot; AS target &#xA;USING &quot; + @[User::DEST_TABLE_FULL_NAME] + &quot; AS source&#xA;ON target.&quot; + @[User::PRIMARY_KEY] + &quot; = source.&quot; + @[User::PRIMARY_KEY] + &quot;&#xA;WHEN MATCHED AND target.[Hash] &lt;&gt; source.[Hash] THEN &#xA;    UPDATE SET &#xA;    &quot; + @[User::DELTA_COLUMNS_MAPPING] +&quot;,LOAD_ID=source.LOAD_ID, LOAD_DATE=source.LOAD_DATE, HASH=source.HASH&#xA;WHEN NOT MATCHED BY TARGET THEN &quot; +&#xA;&quot;    INSERT (&quot;+ @[User::SOURCE_COLUMNS] + &quot;, LOAD_ID, LOAD_DATE, [Hash]) &#xA;     VALUES (&quot;+ @[User::SOURCE_COLUMNS] + &quot;, LOAD_ID, LOAD_DATE, [Hash]) &#xA;OUTPUT &#xA;    $action AS Operation, &#xA;    @ActionLoadID AS Action_LOAD_ID,&#xA;    source.* &#xA;    INTO &quot; + @[User::DELTA_TABLE_FULL_NAME] + &quot;;&#xA;&#xA;&#xA;MERGE &quot; + @[User::ODS_TABLE_FULL_NAME] + &quot; AS target &#xA;USING &quot; + @[User::DEST_TABLE_FULL_NAME] + &quot; AS source&#xA;ON target.&quot; + @[User::PRIMARY_KEY] + &quot; = source.&quot; + @[User::PRIMARY_KEY] + &quot;&#xA;WHEN NOT MATCHED BY SOURCE THEN &#xA;    DELETE &#xA;OUTPUT &#xA;    $action AS Operation,&#xA;    @ActionLoadID AS Action_LOAD_ID,&#xA;    deleted.*&#xA;INTO &quot; + @[User::DELTA_TABLE_FULL_NAME] + &quot;;&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="SQL_MERGE_TO_ODS">
      <DTS:VariableValue
        DTS:DataType="8">DECLARE  @ActionLoadID int=?;

MERGE [ODS].[AWProductCategory] AS target 
USING [Stage].[AWProductCategory] AS source
ON target.ProductCategoryID = source.ProductCategoryID
WHEN MATCHED AND target.[Hash] &lt;&gt; source.[Hash] THEN 
    UPDATE SET 
    ,LOAD_ID=source.LOAD_ID, LOAD_DATE=source.LOAD_DATE, HASH=source.HASH
WHEN NOT MATCHED BY TARGET THEN     INSERT ([ProductCategoryID], [ParentProductCategoryID], [Name], LOAD_ID, LOAD_DATE, [Hash]) 
     VALUES ([ProductCategoryID], [ParentProductCategoryID], [Name], LOAD_ID, LOAD_DATE, [Hash]) 
OUTPUT 
    $action AS Operation, 
    @ActionLoadID AS Action_LOAD_ID,
    source.* 
    INTO [ODS].[AWProductCategory_Delta];


MERGE [ODS].[AWProductCategory] AS target 
USING [Stage].[AWProductCategory] AS source
ON target.ProductCategoryID = source.ProductCategoryID
WHEN NOT MATCHED BY SOURCE THEN 
    DELETE 
OUTPUT 
    $action AS Operation,
    @ActionLoadID AS Action_LOAD_ID,
    deleted.*
INTO [ODS].[AWProductCategory_Delta];</DTS:VariableValue>
    </DTS:Variable>
